@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center">Forgot Password</h2>
            <hr />

            <p class="text-muted">Enter your email address and we will send you a link to reset your password.</p>

            <form method="post" asp-action="ForgotPassword" asp-controller="Account">
                <div class="form-group mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" name="email" class="form-control" required placeholder="name@example.com" />
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Continue</button>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger mt-3">
                        @ViewBag.Error
                    </div>
                }

                @* TEST ONLY: Displays the generated link since SMTP is not configured yet *@
                @if (ViewBag.ResetLink != null)
                {
                    <div class="alert alert-info mt-4" style="border: 2px dashed #0dcaf0;">
                        <strong>Debug Mode:</strong> Password reset link generated successfully.
                        <br />
                        <a href="@ViewBag.ResetLink" class="btn btn-sm btn-info mt-2">Click here to Reset Password</a>
                    </div>
                }
            </form>

            <div class="text-center mt-3">
                <a asp-action="Login" asp-controller="Account" class="text-decoration-none">Back to Login</a>
            </div>
        </div>
    </div>
</div>