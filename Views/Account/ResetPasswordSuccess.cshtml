@{
    ViewData["Title"] = "Password Changed";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                    </div>
                    <h2 class="card-title">Password Reset Successful</h2>
                    <p class="card-text text-muted">
                        Your password has been updated successfully. You can now use your new password to log in to your account.
                    </p>
                    <hr />
                    <div class="d-grid">
                        <a asp-action="Login" asp-controller="Account" class="btn btn-primary">
                            Go to Login Page
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>