<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinalProject</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinalProject.styles.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@400;500&display=swap" rel="stylesheet">
</head>

<body>

    <header>
        <nav class="navbar custom-navbar">

            <div style="width:100%; display:flex; justify-content:space-between; align-items:center;">

                <!-- LOGO LEFT -->
                <nav class="navbar custom-navbar">

                    <div class="nav-left">
                        <a class="navbar-brand"
                               asp-controller="Home"
                               asp-action="Index">
                            Fashion Web
                        </a>
                    </div>

                    <div class="login-right">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="auth-inline">
                                
                                    <span class="welcome-text">
                                    Welcome,
                                    @(User.Identity.Name?.Split('@')[0])
                                    </span>
                                
                                <a href="/Account/Logout" class="logout-link">
                                    Logout
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="auth-inline">
                                <span class="small-text">
                                    Don't have an account?
                                    <a href="/Account/Register" class="register-link">
                                        Register
                                    </a>
                                </span>

                                <a href="/Account/Login" class="login-link">
                                    Login
                                </a>
                            </div>
                        }

                    </div>

                </nav>

        </nav>
    </header>

    <div class="container">
        @RenderBody()
    </div>


    <!-- LOGIN POPUP -->
    <div id="loginPopup" class="login-popup">
        <div class="login-popup-box">

            <h4>Choose an option</h4>

            <div class="login-popup-btns">

                <a href="/Account/Register"
                       class="btn btn-dark">
                    Don't have an account? Register
                </a>

                <a href="/Account/Login"
                       class="btn btn-outline-dark">
                    Already have an account? Login
                </a>

            </div>

            <span onclick="closeLoginPopup()" class="close-popup">
                ×
            </span>

        </div>
    </div>

    <script>
            function openLoginPopup() {
                document.getElementById("loginPopup").style.display = "flex";
            }

            function closeLoginPopup() {
                document.getElementById("loginPopup").style.display = "none";
            }
    </script>

</body>
</html>