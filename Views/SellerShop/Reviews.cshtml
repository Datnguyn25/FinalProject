@model IEnumerable<FinalProject.Models.ShopReview>

@{
    ViewData["Title"] = "Shop Reviews";
    var shop = ViewBag.Shop as FinalProject.Models.Shop;
}

<h1>@ViewData["Title"]</h1>

@if (shop != null)
{
    <p><strong>@shop.ShopName</strong> — Rating: @shop.RatingAverage.ToString("0.00") (@shop.TotalReviews reviews)</p>
}

@if (!Model.Any())
{
    <div class="alert alert-info">No reviews yet.</div>
}
else
{
    <div class="list-group">
        @foreach (var r in Model)
        {
            <div class="list-group-item">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">@r.ReviewerName</h5>
                    <small>@r.CreatedAt.ToString("g")</small>
                </div>
                <p class="mb-1">@r.Comment</p>
                <small>Rating: @r.Rating / 5</small>
                <div class="mt-2">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="ReviewDetails" asp-route-id="@r.ReviewId">View</a>
                </div>
            </div>
        }
    </div>
}       