@model FinalProject.Models.Shop

@{
    ViewData["Title"] = "Edit Shop Info";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
                <label asp-for="ShopName" class="form-label"></label>
                <input asp-for="ShopName" class="form-control" />
                <span asp-validation-for="ShopName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ShopDescription" class="form-label"></label>
                <textarea asp-for="ShopDescription" class="form-control" rows="6"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="ContactEmail" class="form-label"></label>
                <input asp-for="ContactEmail" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="ContactPhone" class="form-label"></label>
                <input asp-for="ContactPhone" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="ShopAddress" class="form-label"></label>
                <input asp-for="ShopAddress" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="City" class="form-label"></label>
                <input asp-for="City" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Country" class="form-label"></label>
                <input asp-for="Country" class="form-control" />
            </div>
        </div>

        <div class="col-md-4">
            <div class="mb-3">
                <label class="form-label">Current Logo</label>
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <div class="mb-2">
                        <img src="~/@Model.LogoUrl" class="img-thumbnail" style="max-width:200px" />
                    </div>
                }
                <label class="form-label">Upload new logo</label>
                <input type="file" name="logoFile" class="form-control" />
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-success">Save</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}