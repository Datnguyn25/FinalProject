@model FinalProject.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<h1>@Model.ProductName</h1>

<div class="row">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.Image))
        {
            <img src="~/@Model.Image" class="img-fluid img-thumbnail" alt="@Model.ProductName" />
        }

        <dl class="row mt-3">
            <dt class="col-sm-5">Price</dt>
            <dd class="col-sm-7">@Model.Price.ToString("C")</dd>

            <dt class="col-sm-5">Promotion</dt>
            <dd class="col-sm-7">@Model.PromotionPrice.ToString("C")</dd>

            <dt class="col-sm-5">Quantity</dt>
            <dd class="col-sm-7">@Model.Quantity</dd>

            <dt class="col-sm-5">Status</dt>
            <dd class="col-sm-7">@(Model.Status ? "Active" : "Inactive")</dd>

            <dt class="col-sm-5">Category</dt>
            <dd class="col-sm-7">@Model.Category?.CateName</dd>

            <dt class="col-sm-5">Brand</dt>
            <dd class="col-sm-7">@Model.Brand?.BrandName</dd>
        </dl>

        <div class="mb-3">
            <a asp-action="Edit" asp-route-id="@Model.ProductID" class="btn btn-primary">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to list</a>
        </div>

        <form asp-action="UpdateInventory" method="post" class="mb-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.ProductID" />
            <div class="input-group">
                <input type="number" name="quantity" value="@Model.Quantity" class="form-control" />
                <button type="submit" class="btn btn-outline-primary">Update Inventory</button>
            </div>
        </form>

        <form asp-action="UpdatePrice" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.ProductID" />
            <div class="input-group">
                <input type="number" step="0.01" name="price" value="@Model.Price" class="form-control" />
                <input type="number" step="0.01" name="promotionPrice" value="@Model.PromotionPrice" class="form-control" />
                <button type="submit" class="btn btn-outline-primary">Update Price</button>
            </div>
        </form>
    </div>

    <div class="col-md-8">
        <h5>Description</h5>
        <p>@Model.ProductDescription</p>

        <h5>Detail</h5>
        <div>@Html.Raw(Model.Detail)</div>

        <h5 class="mt-3">Gallery</h5>
        @if (!string.IsNullOrEmpty(Model.ListImages))
        {
            var imgs = Model.ListImages.Split(',', StringSplitOptions.RemoveEmptyEntries);
            <div class="d-flex flex-wrap gap-2">
                @foreach (var img in imgs)
                {
                    <img src="~/@img.Trim()" class="img-thumbnail" style="max-width:120px" />
                }
            </div>
        }
    </div>
</div>