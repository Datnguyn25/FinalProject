@model FinalProject.ViewModels.SellerDashboardVM

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Inter', sans-serif;
        background: #f5f7fb;
    }

    .dashboard {
        padding: 20px;
    }

    .cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .card {
        background: white;
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

        .card h3 {
            margin: 0;
            color: #888;
        }

        .card h2 {
            margin-top: 10px;
            color: #111;
        }

    .section {
        margin-top: 30px;
        background: white;
        padding: 20px;
        border-radius: 15px;
    }

</style>

<div class="dashboard">

    <h2>🔥 Seller Dashboard</h2>

    <form method="get">
        <input type="date" name="fromDate" />
        <input type="date" name="toDate" />
        <button>Lọc</button>
    </form>

    <!-- 🔥 CARDS -->
    <div class="cards">
        <div class="card">
            <h3>💰 Doanh thu</h3>
            <h2>@Model.TotalRevenue VNĐ</h2>
        </div>

        <div class="card">
            <h3>📦 Đơn hàng</h3>
            <h2>@Model.TotalOrders</h2>
        </div>

        <div class="card">
            <h3>🔥 Sản phẩm bán</h3>
            <h2>@Model.TotalProductsSold</h2>
        </div>
    </div>

    <!-- 🔥 CHART -->
    <div class="section">
        <h3>📊 Doanh thu & Lợi nhuận</h3>
        <canvas id="mainChart"></canvas>
    </div>

    <!-- 🔥 TOP PRODUCT -->
    <div class="section">
        <h3>🔥 Top sản phẩm</h3>

        <table width="100%">
            <tr>
                <th>Tên</th>
                <th>Đã bán</th>
            </tr>

            @foreach (var item in Model.TopProducts)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.TotalSold</td>
                </tr>
            }
        </table>
    </div>

</div>

<!-- SIGNALR -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
    const connection = new signalR.HubConnectionBuilder()
    .withUrl("/orderHub")
    .build();

    connection.start();

    // 🔥 có đơn mới → update chart
    connection.on("NewOrder", function () {
    loadChart();
    });

    // 🔥 update trạng thái → update chart
    connection.on("OrderUpdated", function () {
    loadChart();
    });
</script>

<!-- CHART -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    let chart;

    function loadChart() {
    fetch('/SellerDashboard/GetChartData')
    .then(res => res.json())
    .then(data => {

    let labels = data.map(x => x.date);
    let revenue = data.map(x => x.revenue);
    let profit = data.map(x => x.profit);

    // 🔥 FIX: nếu chỉ có 1 điểm → thêm điểm giả
    if (labels.length === 1) {
    labels.push(labels[0]);
    revenue.push(revenue[0]);
    profit.push(profit[0]);
    }

    // 🔥 FIX: nếu không có dữ liệu
    if (labels.length === 0) {
    labels = ["Không có dữ liệu"];
    revenue = [0];
    profit = [0];
    }

    // destroy chart cũ
    if (chart) chart.destroy();

    const ctx = document.getElementById('mainChart').getContext('2d');

    // 🔥 gradient đẹp
    const gradientRevenue = ctx.createLinearGradient(0, 0, 0, 300);
    gradientRevenue.addColorStop(0, "rgba(54,162,235,0.5)");
    gradientRevenue.addColorStop(1, "rgba(54,162,235,0)");

    const gradientProfit = ctx.createLinearGradient(0, 0, 0, 300);
    gradientProfit.addColorStop(0, "rgba(75,192,192,0.5)");
    gradientProfit.addColorStop(1, "rgba(75,192,192,0)");

    chart = new Chart(ctx, {
    type: 'line',
    data: {
    labels: labels,
    datasets: [
    {
    label: 'Doanh thu',
    data: revenue,
    borderColor: '#36A2EB',
    backgroundColor: gradientRevenue,
    borderWidth: 3,
    pointRadius: 5,
    tension: 0.4,
    fill: true
    },
    {
    label: 'Lợi nhuận',
    data: profit,
    borderColor: '#4BC0C0',
    backgroundColor: gradientProfit,
    borderWidth: 3,
    pointRadius: 5,
    tension: 0.4,
    fill: true
    }
    ]
    },
    options: {
    responsive: true,

    interaction: {
    mode: 'index',
    intersect: false
    },

    plugins: {
    legend: {
    labels: {
    font: {
    size: 14
    }
    }
    },

    tooltip: {
    callbacks: {
    label: function(context) {
    return context.dataset.label + ": " +
    context.raw.toLocaleString() + " VNĐ";
    }
    }
    }
    },

    scales: {
    y: {
    beginAtZero: true,
    ticks: {
    callback: function(value) {
    return value.toLocaleString() + "đ";
    }
    }
    }
    }
    }
    });
    });
    }

    // 🔥 load lần đầu
    loadChart();
</script>