@model FinalProject.Models.Product

<div class="shop-container">

    <h2 class="shop-title-page">🛍 Product Detail</h2>

    <div class="details-container">

        <!-- IMAGE -->
        <div class="details-image">
            <img src="@(Model.Image ?? "/assets/product-1.jpg")" />
        </div>

        <!-- INFO -->
        <div class="details-info">

            <h2 class="details-name">
                @Model.ProductName
            </h2>

            <div class="details-price">
                @Model.Price VNĐ
            </div>

            <div class="details-meta">
                <p><b>Category:</b> @Model.Category?.CateName</p>
                <p><b>Brand:</b> @Model.Brand?.BrandName</p>
                <p><b>Shop:</b> @Model.Shop?.ShopName</p>
            </div>

            <div class="details-desc">
                <b>Description:</b>
                <p>No description available</p>
            </div>

            <div class="details-actions">

                <a href="/Cart/AddToCart?productId=@Model.ProductID"
                   class="details-cart-btn">
                    🛒 Add to Cart
                </a>

                <a href="/Product"
                   class="details-back">
                    ⬅ Back to List
                </a>

            </div>

        </div>

    </div>

</div>