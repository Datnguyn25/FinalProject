@model List<Product>

@{
    var selectedCategory = ViewBag.SelectedCategory as int?;
    var searchType = ViewBag.SearchType as string;
    var minPrice = ViewBag.MinPrice ?? 0;
    var maxPrice = ViewBag.MaxPrice ?? 100000000;
}

<div class="shop-container">

    <div class="shop-layout">

        <!-- ===== SIDEBAR ===== -->
        <div class="shop-sidebar">
            <h5 class="filter-title">Filter by price</h5>

            @{
                var categories = ViewBag.Categories as List<ProductCategory>;
                int? currentParent = null;

                if (selectedCategory != null && categories != null)
                {
                    var current = categories
                        .FirstOrDefault(x => x.CateId == selectedCategory);

                    if (current != null)
                    {
                        currentParent = current.ParentId ?? current.CateId;
                    }
                }
            }

            @if (currentParent != null)
            {
                var hasChild = false;

                foreach (var c in ViewBag.Categories)
                {
                    if (c.ParentId == currentParent)
                    {
                        hasChild = true;
                        break;
                    }
                }

                if (hasChild)
                {
                    <hr />
                    <h5 class="filter-title">Sub Categories</h5>

                    <div class="shop-subcategory">
                        @foreach (var sub in ViewBag.Categories)
                        {
                            if (sub.ParentId == currentParent)
                            {
                                <div>
                                    <a href="/Product?cateId=@sub.CateId"
                                           class="shop-cate @(selectedCategory == sub.CateId ? "active" : "")">
                                        └ @sub.CateName
                                    </a>
                                </div>
                            }
                        }
                    </div>
                }
            }

            <!-- PRICE FILTER -->
            <form method="get" asp-action="Index">
                <input type="hidden" name="cateId" value="@selectedCategory" />
                <input type="hidden" name="keyword" value="@ViewBag.Keyword" />
                <input type="hidden" name="searchType" value="@searchType" />

                <div class="price-filter">
                    <label>Price from: <b>@minPrice</b> VNĐ</label>
                    <input type="range" name="minPrice" min="0" max="1000000" value="@minPrice" />

                    <label>To: <b>@maxPrice</b> VNĐ</label>
                    <input type="range" name="maxPrice" min="0" max="1000000" value="@maxPrice" />
                </div>

                <button type="submit" class="shop-filter-btn">Search</button>
            </form>
        </div>

        <!-- ===== MAIN ===== -->
        <div class="shop-main">

            <form method="get" asp-action="Index" class="shop-search">
                <select name="searchType" class="shop-input">
                    <option value="name">Product Name</option>
                </select>

                <input type="text" name="keyword" value="@ViewBag.Keyword" class="shop-input" />
                <button type="submit" class="shop-btn">Search</button>
            </form>

            <hr />

            <!-- ✅ CATEGORY CHA ONLY -->
            <div class="shop-category">

                <a href="/Product"
                       class="@(selectedCategory == null ? "shop-cate active" : "shop-cate")">
                    All
                </a>

                @foreach (var c in ViewBag.Categories)
                {
                    if (c.ParentId == null) // 👉 chỉ lấy cha
                    {
                        <a href="/Product?cateId=@c.CateId"
                               class="@(selectedCategory == c.CateId ? "shop-cate active" : "shop-cate")">
                            @c.CateName
                        </a>
                    }
                }

            </div>

            <hr />

            <!-- PRODUCT LIST -->
            <div class="shop-grid">
                @foreach (var item in Model)
                {
                    <div class="shop-card">

                            <a href="/Product/Details/@item.ProductId" class="shop-link">

                                <img src="@(string.IsNullOrEmpty(item.Image)
                                                                                                         ? Url.Content("~/assets/product-1.jpg")
                                                                                                         : Url.Content("~/assets/" + item.Image))" />

                        <h4>@item.ProductName</h4>
                        <p>@item.Price.ToString("N0") VNĐ</p>

                        <div class="shop-actions-group">

                                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="actionType" value="buyNow" />
                                  
  

                                    <button type="submit" class="shop-buy-btn">⚡ Buy Now</button>
                                </form>

                                <form onsubmit="addToCart(event, @item.ProductId, '@(string.IsNullOrEmpty(item.Image) ? Url.Content("~/assets/product-1.jpg") : Url.Content("~/assets/" + item.Image))', this)">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="shop-cart-btn">
                                        🛒 Add to Cart
                                    </button>
                                </form>

                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- MODAL SIZE -->
<div id="sizeModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:999;">
    <div style="background:white;padding:20px;width:300px;margin:10% auto;border-radius:10px;text-align:center;">
        <h4>Chọn Size</h4>

        <select id="sizeSelect">
            <option value="S">S</option>
            <option value="M" selected>M</option>
            <option value="L">L</option>
            <option value="XL">XL</option>
        </select>

        <br><br>

        <button onclick="confirmSize()">OK</button>
        <button onclick="closeSize()">Cancel</button>
    </div>
</div>

<script>
    let currentForm = null;
    let currentType = ""; // cart hoặc buy

    document.querySelectorAll(".shop-buy-btn").forEach(btn => {
        btn.addEventListener("click", function () {
            currentForm = this.closest("form");
            currentType = "buy";
            document.getElementById("sizeModal").style.display = "block";
        });
    });

    document.querySelectorAll(".shop-cart-btn").forEach(btn => {
        btn.addEventListener("click", function () {
            currentForm = this.closest("form");
            currentType = "cart";
            document.getElementById("sizeModal").style.display = "block";
        });
    });

    function confirmSize() {
        let size = document.getElementById("sizeSelect").value;

        if (currentType === "buy") {
            let input = document.createElement("input");
            input.type = "hidden";
            input.name = "size";
            input.value = size;
            currentForm.appendChild(input);
            currentForm.submit();
        }

        if (currentType === "cart") {
            let form = currentForm;
            let productId = form.querySelector("input[name='productId']").value;
            let token = form.querySelector("input[name='__RequestVerificationToken']").value;

            fetch('/Cart/AddToCart', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: 'productId=' + productId +
                      '&quantity=1' +
                      '&size=' + size +
                      '&__RequestVerificationToken=' + token
            })
            .then(res => res.json())
            .then(data => {

                if (data.redirect) {
                    window.location.href = data.redirect;
                    return;
                }

                animateCart(data.count, '/assets/product-1.jpg', form);
            });
        }

        closeSize();
    }

    function closeSize() {
        document.getElementById("sizeModal").style.display = "none";
    }

    function animateCart(count, imgSrc, startElement) {
        const badge = document.getElementById("cart-count");
        if (badge) badge.innerText = count;

        const cart = document.querySelector(".floating-cart");
        if (!cart) return;

        const img = document.createElement("img");
        img.src = imgSrc;
        img.style.position = "fixed";
        img.style.zIndex = 999;

        document.body.appendChild(img);

        const start = startElement.getBoundingClientRect();
        const end = cart.getBoundingClientRect();

        img.style.left = start.left + "px";
        img.style.top = start.top + "px";
        img.style.width = "80px";

        setTimeout(() => {
            img.style.left = end.left + "px";
            img.style.top = end.top + "px";
            img.style.width = "20px";
            img.style.opacity = "0.5";
        }, 10);

        setTimeout(() => img.remove(), 800);
    }
</script>