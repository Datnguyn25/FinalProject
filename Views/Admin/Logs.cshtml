@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "System Logs";
}
@model List<FinalProject.Models.SystemLog>

<h2 class="admin-title">📜 System Logs</h2>

<div class="table-responsive">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Time</th>
                <th>User</th>
                <th>Action</th>
                <th>Details</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td style="font-size: 0.85rem; color: #666;">
                        @log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")
                    </td>
                    <td><strong>@log.UserId</strong></td>

                    <td>
                        @* Tự động đổi màu Badge dựa trên loại Action *@
                        @{
                            var badgeClass = log.Action.ToLower() switch
                            {
                                var a when a.Contains("login") => "badge-info",
                                var a when a.Contains("create") || a.Contains("add") => "badge-success",
                                var a when a.Contains("delete") || a.Contains("remove") => "badge-danger",
                                var a when a.Contains("update") || a.Contains("edit") => "badge-warning",
                                _ => "badge-secondary"
                            };
                        }
                        <span class="admin-badge @badgeClass">
                            @log.Action
                        </span>
                    </td>

                    <td>
                        <div style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@log.Details">
                            @log.Details
                        </div>
                    </td>

                    <td>
                        @* Nút View chi tiết *@
                        <button class="btn-view-log" onclick="showLogDetails('@log.Action', '@log.Details', '@log.Timestamp')">
                            👁️ View
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="logModal" class="modal-custom">
    <div class="modal-content">
        <span class="close" onclick="closeModal()">&times;</span>
        <h3>Log Details</h3>
        <hr>
        <p><strong>Action:</strong> <span id="modalAction"></span></p>
        <p><strong>Time:</strong> <span id="modalTime"></span></p>
        <p><strong>Description:</strong></p>
        <div id="modalDetails" class="details-box"></div>
    </div>
</div>

<style>
    .btn-view-log {
        background: #333;
        color: white;
        border: none;
        padding: 5px 12px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.8rem;
    }
    .badge-info { background: #17a2b8; color: white; }
    .badge-success { background: #28a745; color: white; }
    .badge-danger { background: #dc3545; color: white; }
    .badge-warning { background: #ffc107; color: #212529; }

    /* Simple Modal CSS */
    .modal-custom {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0; top: 0; width: 100%; height: 100%;
        background-color: rgba(0,0,0,0.5);
    }
    .modal-content {
        background-color: white;
        margin: 15% auto;
        padding: 20px;
        width: 40%;
        border-radius: 8px;
    }
    .details-box {
        background: #f4f4f4;
        padding: 10px;
        border-radius: 4px;
        border-left: 4px solid #333;
    }
</style>

<script>
    function showLogDetails(action, details, time) {
        document.getElementById("modalAction").innerText = action;
        document.getElementById("modalTime").innerText = time;
        document.getElementById("modalDetails").innerText = details;
        document.getElementById("logModal").style.display = "block";
    }

    function closeModal() {
        document.getElementById("logModal").style.display = "none";
    }

    window.onclick = function(event) {
        if (event.target == document.getElementById("logModal")) {
            closeModal();
        }
    }
</script>