@model FinalProject.Models.Product

<div class="container-fluid">
    <div class="row">
        <div class="col-md-5 border-end">
            <h6>Main Image:</h6>
            @* Sửa lại đường dẫn ở đây *@
            <img src="/assets/@Model.Image" class="img-fluid rounded mb-3 border" alt="Main"
                 onerror="this.src='/assets/no-image.png';" />

            <h6>Gallery Images:</h6>
            <div class="d-flex flex-wrap gap-2">
                @if (!string.IsNullOrEmpty(Model.ListImages))
                {
                    foreach (var img in Model.ListImages.Split(','))
                    {
                        @* Sửa lại đường dẫn và thêm Trim() để xóa khoảng trắng thừa *@
                        <img src="/assets/@img.Trim()"
                             style="width: 70px; height: 70px; object-fit: cover;"
                             class="border rounded"
                             onerror="this.src='/assets/no-image.png';" />
                    }
                }
            </div>
        </div>

        <div class="col-md-7">
            <h4 class="text-primary">@Model.ProductName</h4>
            <p class="text-muted"><i>@Model.SeoTitle</i></p>
            <hr />

            <div class="row">
                <div class="col-6">
                    <p><strong>Price:</strong> <span class="text-danger">$@Model.Price.ToString("N2")</span></p>
                    <p><strong>Stock Quantity:</strong> @Model.Quantity</p>
                    <p><strong>Category:</strong> @Model.Category?.CateName</p>
                    <p><strong>Brand:</strong> @Model.Brand?.BrandName</p>
                    <p><strong>Shop Owner:</strong> @Model.Shop?.ShopName</p>
                </div>
                <div class="col-6">
                    <p><strong>Status:</strong> @(Model.Status ? "Active" : "Hidden")</p>
                    <p><strong>Hot Product:</strong> @(Model.Hot ? "Yes" : "No")</p>
                    <p><strong>VAT Included:</strong> @(Model.VAT ? "Yes" : "No")</p>
                    <p><strong>View Count:</strong> @Model.ViewCount</p>
                    <p><strong>Created Date:</strong> @Model.CreatedDate.ToString("dd/MM/yyyy")</p>
                </div>
            </div>

            <div class="mt-3">
                <h6>Short Description:</h6>
                <p class="small text-secondary">@Model.ProductDescription</p>

                <h6>Full Detail:</h6>
                <div class="p-2 border bg-light small" style="max-height: 150px; overflow-y: auto;">
                    @Html.Raw(Model.Detail)
                </div>
            </div>

            <div class="mt-3">
                <h6>SEO Meta:</h6>
                <small><strong>Keywords:</strong> @Model.MetaKeywords</small><br />
                <small><strong>Description:</strong> @Model.MetaDescription</small>
            </div>
        </div>
    </div>
</div>